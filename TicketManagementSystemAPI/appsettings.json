{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "myConnectionString": "Server=server_name;Database=database_name;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "jwt_key",
    "Issuer": "https://localhost:7059",
    "Audience": "*",
    "TokenExpiryMinutes": 60
  }
}
